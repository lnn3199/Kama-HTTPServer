prefix=/usr/local
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: SimpleAmqpClient
Description: C++ wrapper of rabbitmq-c AMQP client library
Version: 2.6.0
Requires.private: librabbitmq
Libs: -L${libdir} -lSimpleAmqpClient 
Libs.private:  -L"/usr/lib/x86_64-linux-gnu" -lboost_chrono.so.1.83 -lboost_system.so.1.83
CFlags: -I${includedir} -I"/usr/include" 
